{
  "manifest_version": 3,
  "name": "ClaudeScope",
  "description": "Lekki licznik limitow, czasu aktywnosci i platnosci dla claude.ai od ogarniamy.ai. Dane zostaja na Twoim urzadzeniu.",
  "version": "1.2.1",
  "icons": {
    "16": "assets/mark-16.png",
    "32": "assets/mark-32.png",
    "48": "assets/mark-48.png",
    "128": "assets/mark-128.png"
  },
  "action": {
    "default_title": "ClaudeScope",
    "default_icon": {
      "16": "assets/mark-16.png",
      "32": "assets/mark-32.png",
      "48": "assets/mark-48.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "run_at": "document_idle",
      "js": [
        "src/core/ns.js",
        "src/core/semver.js",
        "src/core/clock.js",
        "src/core/labels.js",
        "src/core/reach.js",
        "src/core/shape.js",
        "src/core/vault.js",
        "src/core/wire.js",
        "src/feed/caller.js",
        "src/feed/settings.js",
        "src/feed/org.js",
        "src/feed/sources.js",
        "src/feed/peakwin.js",
        "src/capture/relay.js",
        "src/pulse/presence.js",
        "src/pulse/ledger.js",
        "src/pulse/usagelog.js",
        "src/pulse/rollup.js",
        "src/surface/skin.js",
        "src/surface/pieces/glyph.js",
        "src/surface/pieces/meter.js",
        "src/surface/pieces/dial.js",
        "src/surface/pieces/stopwatch.js",
        "src/surface/pieces/peakflag.js",
        "src/surface/pieces/clockface.js",
        "src/surface/pieces/ranger.js",
        "src/surface/pieces/spark.js",
        "src/surface/rail.js",
        "src/surface/drawer.js",
        "src/surface/host.js",
        "src/boot.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["https://claude.ai/*"],
      "resources": [
        "src/capture/model-reader.injected.js",
        "config/runtime.config.json",
        "assets/logo-inverted.svg"
      ]
    }
  ]
}
